rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function orgPath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId);
    }

    function orgExists(orgId) {
      return exists(orgPath(orgId));
    }

    function orgData(orgId) {
      return get(orgPath(orgId)).data;
    }

    function isOrgActive(orgId) {
      return orgExists(orgId)
        && (
          orgData(orgId).isActive == true
          || !("isActive" in orgData(orgId))
        );
    }

    function featurePath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId)/settings/adminFeatures;
    }

    function featureExists(orgId) {
      return exists(featurePath(orgId));
    }

    function featureData(orgId) {
      return get(featurePath(orgId)).data;
    }

    function isFeatureEnabled(orgId, featureName) {
      return !featureExists(orgId)
        || !(featureName in featureData(orgId))
        || featureData(orgId)[featureName] == true;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid))
        && get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data.isActive == true;
    }

    function isAdmin(orgId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/$(orgId)/admins/$(request.auth.uid)).data.isActive == true;
    }

    function isAdminOrSuperAdmin(orgId) {
      return isAdmin(orgId) || isSuperAdmin();
    }

    function isOwnMemberDoc(memberId) {
      return isSignedIn() && request.auth.uid == memberId;
    }

    function isPublicMessageEnabled(orgId) {
      return isFeatureEnabled(orgId, "publicAnnouncementEnabled");
    }

    function isMemberMessageEnabled(orgId) {
      return isFeatureEnabled(orgId, "memberMessageEnabled");
    }

    function isReadableMessage(orgId) {
      return isSignedIn()
        && isOrgActive(orgId)
        && (
          (
            resource.data.visibility == "public"
            && isPublicMessageEnabled(orgId)
          )
          ||
          (
            resource.data.visibility == "member"
            && isMemberMessageEnabled(orgId)
          )
          ||
          (
            !("visibility" in resource.data)
            && (
              isPublicMessageEnabled(orgId)
              || isMemberMessageEnabled(orgId)
            )
          )
        );
    }

    function isWritableMessage(orgId) {
      return isAdminOrSuperAdmin(orgId)
        && (
          isPublicMessageEnabled(orgId)
          || isMemberMessageEnabled(orgId)
        );
    }

    match /superAdmins/{uid} {
      allow read: if isSuperAdmin();
      allow create, update: if isSuperAdmin();
      allow delete: if false;
    }

    match /organizations/{organizationId} {

      allow get:
        if resource.data.isActive == true
        || !("isActive" in resource.data)
        || isAdminOrSuperAdmin(organizationId);

      allow list:
        if isSuperAdmin();

      allow create, update:
        if isSuperAdmin();

      allow delete:
        if false;

      match /settings/{settingId} {

        allow read:
          if isAdminOrSuperAdmin(organizationId)
          || (
            settingId == "adminFeatures"
            && isSignedIn()
            && isOrgActive(organizationId)
          );

        allow create, update:
          if isSuperAdmin();

        allow delete:
          if isSuperAdmin();
      }

      match /admins/{adminId} {
        allow read:
          if isAdminOrSuperAdmin(organizationId)
          || (isSignedIn() && request.auth.uid == adminId);

        allow create, update:
          if isSuperAdmin();

        allow delete:
          if isSuperAdmin();
      }

      match /members/{memberId} {
        allow read:
          if isOwnMemberDoc(memberId)
          || isAdminOrSuperAdmin(organizationId);

        allow create:
          if isOwnMemberDoc(memberId);

        allow update:
          if isOwnMemberDoc(memberId)
          || isAdminOrSuperAdmin(organizationId);

        allow delete:
          if isAdminOrSuperAdmin(organizationId);
      }

      match /memberRegistrations/{registrationId} {
        allow create:
          if isSignedIn();

        allow read, update, delete:
          if isAdminOrSuperAdmin(organizationId);
      }

      match /messages/{messageId} {
        allow read:
          if isReadableMessage(organizationId);

        allow create, update, delete:
          if isWritableMessage(organizationId);
      }

      match /categories/{categoryId} {
        allow read:
          if isSignedIn()
          && (
            isPublicMessageEnabled(organizationId)
            || isMemberMessageEnabled(organizationId)
          );

        allow create, update, delete:
          if isAdminOrSuperAdmin(organizationId)
          && (
            isPublicMessageEnabled(organizationId)
            || isMemberMessageEnabled(organizationId)
          );
      }

      match /videos/{videoId} {
        allow read:
          if isSignedIn()
          && isOrgActive(organizationId)
          && isFeatureEnabled(organizationId, "videoEnabled");

        allow create, update:
          if isAdminOrSuperAdmin(organizationId)
          && isFeatureEnabled(organizationId, "videoEnabled")
          && (
            request.resource.data.isPremium != true
            || isFeatureEnabled(organizationId, "paidVideoEnabled")
          );

        allow delete:
          if isAdminOrSuperAdmin(organizationId)
          && isFeatureEnabled(organizationId, "videoEnabled");
      }

      match /videoWatchLogs/{logId} {
        allow read:
          if isAdminOrSuperAdmin(organizationId)
          || (
            isSignedIn()
            && resource.data.memberUid == request.auth.uid
            && isFeatureEnabled(organizationId, "videoEnabled")
          );

        allow create:
          if isSignedIn()
          && isOrgActive(organizationId)
          && isFeatureEnabled(organizationId, "videoEnabled")
          && request.resource.data.memberUid == request.auth.uid;

        allow update:
          if isAdminOrSuperAdmin(organizationId)
          || (
            isSignedIn()
            && isOrgActive(organizationId)
            && isFeatureEnabled(organizationId, "videoEnabled")
            && resource.data.memberUid == request.auth.uid
            && request.resource.data.memberUid == request.auth.uid
          );

        allow delete:
          if isAdminOrSuperAdmin(organizationId);
      }

      match /bookingEvents/{eventId} {
        allow read:
          if isSignedIn()
          && isOrgActive(organizationId)
          && isFeatureEnabled(organizationId, "bookingEnabled");

        allow create, update, delete:
          if isAdminOrSuperAdmin(organizationId)
          && isFeatureEnabled(organizationId, "bookingEnabled");

        match /slots/{slotId} {
          allow read:
            if isSignedIn()
            && isOrgActive(organizationId)
            && isFeatureEnabled(organizationId, "bookingEnabled");

          allow create, update, delete:
            if isAdminOrSuperAdmin(organizationId)
            && isFeatureEnabled(organizationId, "bookingEnabled");
        }

        match /reservations/{reservationId} {
          allow read:
            if isAdminOrSuperAdmin(organizationId)
            || (
              isSignedIn()
              && resource.data.memberUid == request.auth.uid
              && isFeatureEnabled(organizationId, "bookingEnabled")
            );

          allow create:
            if isSignedIn()
            && isFeatureEnabled(organizationId, "bookingEnabled")
            && request.resource.data.memberUid == request.auth.uid;

          allow update:
            if isAdminOrSuperAdmin(organizationId)
            || (
              isSignedIn()
              && resource.data.memberUid == request.auth.uid
              && isFeatureEnabled(organizationId, "bookingEnabled")
            );

          allow delete:
            if isAdminOrSuperAdmin(organizationId)
            || (
              isSignedIn()
              && resource.data.memberUid == request.auth.uid
              && isFeatureEnabled(organizationId, "bookingEnabled")
            );
        }
      }

      match /private/{docId} {
        allow read, write:
          if isAdminOrSuperAdmin(organizationId)
          && isFeatureEnabled(organizationId, "videoEnabled");
      }

      match /fcmTokens/{tokenId} {
        allow read:
          if isAdminOrSuperAdmin(organizationId);

        allow create, update:
          if isSignedIn();

        allow delete:
          if isSignedIn();
      }

      match /devices/{deviceId} {
        allow read:
          if isAdminOrSuperAdmin(organizationId);

        allow create, update:
          if isSignedIn();

        allow delete:
          if isSignedIn();
      }

      match /memberPosts/{postId} {
        allow read:
          if isAdminOrSuperAdmin(organizationId)
          || (
            isSignedIn()
            && resource.data.memberUid == request.auth.uid
          );

        allow create:
          if isSignedIn()
          && isMemberMessageEnabled(organizationId)
          && request.resource.data.memberUid == request.auth.uid;

        allow update:
          if isAdminOrSuperAdmin(organizationId)
          || (
            isSignedIn()
            && resource.data.memberUid == request.auth.uid
          );

        allow delete:
          if isAdminOrSuperAdmin(organizationId);

        match /replies/{replyId} {
          allow read:
            if isAdminOrSuperAdmin(organizationId)
            || (
              isSignedIn()
              && get(
                /databases/$(database)/documents/organizations/$(organizationId)/memberPosts/$(postId)
              ).data.memberUid == request.auth.uid
            );

          allow create, update, delete:
            if isAdminOrSuperAdmin(organizationId);
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
